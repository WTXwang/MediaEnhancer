<Window x:Class="MediaEnhancer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaEnhancer"
        mc:Ignorable="d"
        Title="影音智增强管理系统" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei">
    <Window.Resources>
        <!-- 导航按钮样式，带有悬浮效果以提供视觉反馈 -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 普通操作按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <!-- 左侧导航栏 -->
            <ColumnDefinition Width="220"/>
            <!-- 右侧主体内容区 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航区 -->
        <Border Grid.Column="0" Background="#F0F4F8" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
            <StackPanel Margin="15,30,15,10">
                <TextBlock Text="影音智增强" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="10,0,0,30"/>

                <Button Content="📂 文件管理" Style="{StaticResource NavButtonStyle}"/>
                <Button Content="✨ 实时增强" Style="{StaticResource NavButtonStyle}" Command="{Binding ShowNotImplementedMsgCommand}" CommandParameter="实时增强"/>
                <Button Content="⏺ 屏幕录制" Style="{StaticResource NavButtonStyle}" Command="{Binding ShowNotImplementedMsgCommand}" CommandParameter="屏幕录制"/>
                <Button Content="🤖 AI 总结" Style="{StaticResource NavButtonStyle}" Command="{Binding ShowNotImplementedMsgCommand}" CommandParameter="AI总结"/>
                <Button Content="⚙ 系统设置" Style="{StaticResource NavButtonStyle}" Command="{Binding ShowNotImplementedMsgCommand}" CommandParameter="系统设置"/>
            </StackPanel>
        </Border>

        <!-- 右侧主体内容区 (暂时默认显示文件管理面板) -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 面板标题 -->
            <TextBlock Grid.Row="0" Text="我的影音库" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,20"/>

            <!-- 操作栏 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="➕ 导入文件" Style="{StaticResource ActionButtonStyle}" Margin="0,0,10,0" Command="{Binding ShowNotImplementedMsgCommand}" CommandParameter="导入文件"/>
                <Button Content="🔄 刷新列表" Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshCommand}"/>
            </StackPanel>

            <!-- 数据展示区 (替代留白，暂用DataGrid) -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding MediaFilesList}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="White" RowBackground="White" AlternatingRowBackground="#F9FAFB"
                      BorderBrush="#E5E7EB" BorderThickness="1" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="250"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="首次导入时间" Binding="{Binding DateAdded, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                    <DataGridCheckBoxColumn Header="收藏" Binding="{Binding IsFavorite}" Width="60"/>
                    <DataGridTextColumn Header="文件路径" Binding="{Binding FilePath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
