<Window x:Class="MediaEnhancer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaEnhancer"
        mc:Ignorable="d"
        Title="影音智增强管理系统" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧导航栏 -->
            <ColumnDefinition Width="200"/>
            <!-- 右侧主体内容区 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="控制面板" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                <Button Content="所有文件" Margin="0,5" Padding="5"/>
                <!-- 预留实时增强等功能的按钮，暂时隐藏或者不可点状态 -->
                <Button Content="实时增强 (待开发)" Margin="0,5" Padding="5" IsEnabled="False"/>
                <Button Content="录屏功能 (待开发)" Margin="0,5" Padding="5" IsEnabled="False"/>
                <Button Content="系统设置" Margin="0,5" Padding="5"/>
            </StackPanel>
        </Border>

        <!-- 右侧主体，目前展示数据列表 -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="手动添加测试数据" Width="120" Margin="0,0,10,0"/>
                <Button Content="刷新列表" Command="{Binding RefreshCommand}" Width="80"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding MediaFilesList}" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="200"/>
                    <DataGridTextColumn Header="文件路径" Binding="{Binding FilePath}" Width="*"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="100"/>
                    <DataGridCheckBoxColumn Header="已收藏" Binding="{Binding IsFavorite}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
