using System;

namespace MediaEnhancer.Models
{
    /// <summary>
    /// 表示一个媒体文件实体。
    /// </summary>
    public class MediaFile
    {
        /// <summary>
        /// 获取或设置媒体文件的唯一标识符。
        /// </summary>
        public int Id { get; set; }

        /// <summary>
        /// 获取或设置媒体文件的标题。
        /// </summary>
        public string Title { get; set; }

        /// <summary>
        /// 获取或设置媒体文件的本地文件路径。
        /// </summary>
        public string FilePath { get; set; }

        /// <summary>
        /// 获取或设置媒体文件的类型（如 "Video", "Image"）。
        /// 本项目不处理音频文件。
        /// </summary>
        public string Type { get; set; }

        /// <summary>
        /// 获取或设置该媒体文件是否已被用户收藏。
        /// </summary>
        public bool IsFavorite { get; set; }

        /// <summary>
        /// 获取或设置媒体文件首次导入(添加)到系统的时间。
        /// </summary>
        public DateTime DateAdded { get; set; }

        /// <summary>
        /// 获取或设置该系统对该文件记录的最后一次修改时间。
        /// </summary>
        public DateTime DateModified { get; set; }

        /// <summary>
        /// 获取或设置该媒体文件生成的缩略图(封面)/预览文件的存放路径。
        /// </summary>
        public string ThumbnailPath { get; set; }
    }
}