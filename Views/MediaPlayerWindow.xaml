<Window x:Class="MediaEnhancer.Views.MediaPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="媒体播放器" Height="540" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FontFamily="Microsoft YaHei"
        Background="#1E1E1E"
        Foreground="White"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频/音频播放区域 -->
        <Grid Grid.Row="0">
            <MediaElement x:Name="MediaPlayer"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          MediaOpened="MediaPlayer_MediaOpened"
                          MediaEnded="MediaPlayer_MediaEnded"
                          Stretch="Uniform"/>

            <!-- 音频模式的占位封面 -->
            <Border x:Name="AudioPlaceholder"
                    Background="#2D2D2D"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎵" FontSize="80"/>
                    <TextBlock x:Name="AudioTitleText"
                               FontSize="18"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 控制栏 -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 进度条 -->
                <Slider Grid.Row="0"
                        x:Name="ProgressSlider"
                        Minimum="0" Maximum="100" Value="0"
                        Margin="0,0,0,6"
                        ValueChanged="ProgressSlider_ValueChanged"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        PreviewMouseUp="ProgressSlider_PreviewMouseUp"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 播放控制 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="PrevButton" Content="⏮" Width="32" Height="28"
                                Background="Transparent" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="16"
                                Click="Prev_Click" Margin="0,0,4,0"/>
                        <Button x:Name="PlayPauseButton" Content="▶" Width="40" Height="28"
                                Background="#2563EB" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="16"
                                Click="PlayPause_Click" Margin="0,0,4,0"/>
                        <Button x:Name="NextButton" Content="⏭" Width="32" Height="28"
                                Background="Transparent" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="16"
                                Click="Next_Click" Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- 时间显示 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentTimeText" Text="00:00" FontSize="12" Foreground="#AAAAAA"/>
                        <TextBlock Text=" / " FontSize="12" Foreground="#666666"/>
                        <TextBlock x:Name="TotalTimeText" Text="00:00" FontSize="12" Foreground="#AAAAAA"/>
                    </StackPanel>

                    <!-- 间隔 -->
                    <TextBlock Grid.Column="2" Text=""/>

                    <!-- 音量 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="🔊" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.8"
                                Width="80" VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- 全屏按钮 -->
                    <Button Grid.Column="4" Content="⛶" Width="32" Height="28"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="16"
                            Click="Fullscreen_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
