<Window x:Class="MediaEnhancer.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="影音智增强管理系统 - 登录"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei">

    <Border Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="8" Color="#000000" Opacity="0.15" BlurRadius="24"/>
        </Border.Effect>
        <Grid Margin="40,30,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 0: 关闭按钮 -->
                <RowDefinition Height="Auto"/>   <!-- 1: 标题 -->
                <RowDefinition Height="Auto"/>   <!-- 2: Tab -->
                <RowDefinition Height="Auto"/>   <!-- 3: 用户名标签 -->
                <RowDefinition Height="Auto"/>   <!-- 4: 用户名输入 -->
                <RowDefinition Height="Auto"/>   <!-- 5: 显示名标签(注册) -->
                <RowDefinition Height="Auto"/>   <!-- 6: 显示名输入(注册) -->
                <RowDefinition Height="Auto"/>   <!-- 7: 密码标签 -->
                <RowDefinition Height="Auto"/>   <!-- 8: 密码输入 -->
                <RowDefinition Height="Auto"/>   <!-- 9: 错误消息 -->
                <RowDefinition Height="Auto"/>   <!-- 10: 登录/注册按钮 -->
                <RowDefinition Height="Auto"/>   <!-- 11: 底部链接 -->
            </Grid.RowDefinitions>

            <!-- 关闭按钮（右上角） -->
            <Button Grid.Row="0" Content="✕" Width="28" Height="28"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="#94A3B8"
                    BorderThickness="0" Cursor="Hand" FontSize="14"
                    Click="CloseButton_Click"
                    Margin="0,-10,-10,0"/>

            <!-- 标题 -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="影音智增强" FontSize="26" FontWeight="Bold"
                           Foreground="#0F172A" HorizontalAlignment="Center"/>
                <TextBlock Text="MediaEnhancer" FontSize="12"
                           Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 模式切换 Tab：整个点击区域在 code-behind 处理 -->
            <Border Grid.Row="2" Background="#F1F5F9" CornerRadius="8" Padding="4"
                    Margin="0,0,0,20" MouseLeftButtonDown="TabBar_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="LoginTabBg" Grid.Column="0" CornerRadius="6" Padding="10,6"
                             Background="White">
                        <TextBlock x:Name="LoginTabText" Text="登 录" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#0F172A"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Border x:Name="RegisterTabBg" Grid.Column="1" CornerRadius="6" Padding="10,6"
                             Background="Transparent">
                        <TextBlock x:Name="RegisterTabText" Text="注 册" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#64748B"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 用户名 -->
            <TextBlock Grid.Row="3" Text="用户名" FontSize="13" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Grid.Row="4" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent"
                         FontSize="14" Foreground="#0F172A" VerticalAlignment="Center"/>
            </Border>

            <!-- 显示名称（仅注册模式） -->
            <TextBlock x:Name="DisplayLabel" Grid.Row="5" Text="显示名称" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6" Visibility="Collapsed"/>
            <Border x:Name="DisplayBox" Grid.Row="6" Background="#F8FAFC" BorderBrush="#CBD5E1"
                    BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                    Visibility="Collapsed">
                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent"
                         FontSize="14" Foreground="#0F172A" VerticalAlignment="Center"/>
            </Border>

            <!-- 密码 -->
            <TextBlock Grid.Row="7" Text="密码" FontSize="13" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Grid.Row="8" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                <PasswordBox x:Name="PwdBox"
                             PasswordChanged="PwdBox_PasswordChanged"
                             KeyDown="PwdBox_KeyDown"
                             BorderThickness="0" Background="Transparent"
                             FontSize="14" Foreground="#0F172A"/>
            </Border>

            <!-- 错误消息 -->
            <TextBlock Grid.Row="9" Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="#EF4444" TextWrapping="Wrap" Margin="0,4,0,0"/>

            <!-- 登录/注册按钮 -->
            <Button Grid.Row="10" Content="{Binding ModeButtonText}"
                    Command="{Binding SubmitCommand}"
                    Height="42" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2563EB"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 底部模式切换链接 -->
            <TextBlock x:Name="SwitchLink" Grid.Row="11"
                       Text="还没有账号？点击注册"
                       HorizontalAlignment="Center"
                       Foreground="#2563EB" FontSize="12"
                       Cursor="Hand" TextDecorations="Underline"
                       MouseLeftButtonDown="SwitchMode_Click"/>
        </Grid>
    </Border>
</Window>
