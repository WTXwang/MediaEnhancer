<Window x:Class="MediaEnhancer.Views.DeleteConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除文件" Height="240" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei"
        Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,18,24,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <!-- 警告图标 + 标题 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="⚠" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                           Foreground="#0F172A" VerticalAlignment="Center"
                           Text="确定要删除该文件吗？"/>
            </StackPanel>

            <!-- 文件名 -->
            <Border Background="#FEF2F2" CornerRadius="6" Padding="12,10"
                    Margin="0,0,0,10">
                <TextBlock FontSize="13" Foreground="#991B1B" TextWrapping="Wrap" LineHeight="20">
                    <Run Text="📁 " FontSize="14"/><Run x:Name="NameText" FontWeight="SemiBold"/>
                </TextBlock>
            </Border>

            <!-- 路径 -->
            <TextBlock x:Name="FileText" FontSize="12" Foreground="#94A3B8"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="删除源文件及记录"
                    Style="{StaticResource DlgButton}"
                    Background="#DC2626" Foreground="White"
                    Margin="0,0,8,0"
                    Click="DeleteSource_Click"/>
            <Button Content="仅删除记录"
                    Style="{StaticResource DlgButton}"
                    Background="#F59E0B" Foreground="White"
                    Margin="0,0,8,0"
                    Click="DeleteRecord_Click"/>
            <Button Content="取消"
                    Style="{StaticResource DlgButton}"
                    Background="White" Foreground="#475569"
                    BorderBrush="#CBD5E1" BorderThickness="1"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
