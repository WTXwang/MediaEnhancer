<Window x:Class="MediaEnhancer.Views.DeleteConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除文件" Height="200" Width="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei"
        Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 提示文字 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"
                       Text="确定要删除该文件吗？" Margin="0,0,0,6"/>
            <TextBlock x:Name="FileText" FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 按钮组 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="删除源文件（文件+记录）"
                    Width="160" Height="36"
                    Background="#DC2626"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13"
                    Margin="0,0,8,0"
                    Click="DeleteSource_Click"/>
            <Button Content="仅删除记录"
                    Width="120" Height="36"
                    Background="#F59E0B"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="13"
                    Margin="0,0,8,0"
                    Click="DeleteRecord_Click"/>
            <Button Content="取消"
                    Width="80" Height="36"
                    Background="White"
                    Foreground="#475569"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Cursor="Hand"
                    FontSize="13"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
