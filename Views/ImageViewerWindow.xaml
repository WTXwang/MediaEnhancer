<Window x:Class="MediaEnhancer.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片查看器" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FontFamily="Microsoft YaHei"
        Background="#1E1E1E"
        Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 图片显示区（ScrollViewer 支持缩放后拖动查看） -->
        <ScrollViewer Grid.Row="0" x:Name="ImageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
            <Grid x:Name="ImageContainer">
                <Image x:Name="DisplayImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="20"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.LayoutTransform>
                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                    </Image.LayoutTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- 工具栏 -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⊟ 适应窗口" Width="90" Height="30"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="13"
                        Click="FitToWindow_Click" Margin="0,0,6,0"/>
                <Button Content="1:1 实际大小" Width="90" Height="30"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="13"
                        Click="ActualSize_Click" Margin="0,0,6,0"/>
                <TextBlock x:Name="ZoomText" Text="100%"
                           FontSize="13" Foreground="#AAA"
                           VerticalAlignment="Center" Margin="0,0,6,0"
                           MinWidth="45" TextAlignment="Center"/>

                <Button Content="−" Width="28" Height="28"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="16"
                        Click="ZoomOut_Click" Margin="0,0,2,0"/>
                <Button Content="+" Width="28" Height="28"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="16"
                        Click="ZoomIn_Click" Margin="0,0,8,0"/>

                <Button x:Name="PrevImageButton" Content="◀ 上一张" Width="80" Height="30"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="13"
                        Click="PrevImage_Click" Margin="0,0,4,0"/>
                <TextBlock x:Name="ImageCounter" Text="1 / 1"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Button x:Name="NextImageButton" Content="下一张 ▶" Width="80" Height="30"
                        Background="Transparent" Foreground="White"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="13"
                        Click="NextImage_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
