<Window x:Class="MediaEnhancer.Views.FileDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件详情" Height="520" Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FontFamily="Microsoft YaHei"
        Background="#F8FAFC">
    <Window.Resources>
        <!-- 详情标签样式 -->
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <!-- 详情值样式 -->
        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <!-- 分隔卡片样式 -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="文件详情" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock x:Name="TitleText" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：缩略图 -->
            <Border Grid.Column="0"
                    Style="{StaticResource InfoCardStyle}"
                    Margin="0,0,16,0"
                    Height="240">
                <Grid>
                    <Image x:Name="ThumbnailImage"
                           Width="200" Height="200"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                    <!-- 无缩略图时的占位 -->
                    <Border x:Name="PlaceholderBorder"
                            Background="#F1F5F9"
                            CornerRadius="8"
                            Width="200" Height="200"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🖼" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="暂无缩略图"
                                       FontSize="13"
                                       Foreground="#94A3B8"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧：文件信息 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 基本信息 -->
                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="IdText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="类型" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="TypeText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="格式" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FormatText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="大小" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="SizeText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="分辨率" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DimensionText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="2" Grid.Column="2" Text="时长" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="DurationText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="收藏" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="FavoriteText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="入库时间" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AddedText" Style="{StaticResource DetailValueStyle}"/>

                            <TextBlock Grid.Row="4" Grid.Column="2" Text="修改时间" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" x:Name="ModifiedText" Style="{StaticResource DetailValueStyle}"/>
                        </Grid>
                    </Border>

                    <!-- 路径信息 -->
                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="文件路径" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock x:Name="PathText"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="缩略图路径" Style="{StaticResource DetailLabelStyle}"/>
                            <TextBlock x:Name="ThumbPathText"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
