<Window x:Class="MediaEnhancer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:core="clr-namespace:MediaEnhancer.Core"
        mc:Ignorable="d"
        Title="影音智增强系统" Height="750" Width="1200"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        FontFamily="Microsoft YaHei"
        Background="#F8FAFC">
    <Window.Resources>
        <!-- 页面切换转换器 -->
        <core:IndexToVisibilityConverter x:Key="IndexToVisibilityConverter" />
        <!-- 布尔值 ↔ 可见性转换器 -->
        <core:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!-- 布尔值 ↔ 收藏图标转换器 -->
        <core:BoolToFavoriteConverter x:Key="BoolToFavoriteConverter" />
        <!-- 文件路径 → 不锁定的 BitmapImage -->
        <core:FilePathToImageConverter x:Key="FilePathToImageConverter" />
        <!-- 缩略图路径 → BitmapImage -->
        <core:ThumbnailConverter x:Key="ThumbnailConverter" />
        <!-- Markdown 文本 → TextBlock -->
        <core:MarkdownTextConverter x:Key="MarkdownTextConverter" />
        <!-- 布尔取反 -->
        <core:InvertBoolConverter x:Key="InvertBoolConverter" />
        <!-- 页面索引相等判断（导航按钮高亮用） -->
        <core:PageEqConverter x:Key="PageEqConverter" />

        <!-- ============================================================ -->
        <!-- 基础颜色与尺寸常量（统一管理，方便后续整体换肤）              -->
        <!-- ============================================================ -->

        <!-- 配色方案：
             侧边栏背景    #F1F5F9
             主背景        #F8FAFC
             卡片背景      #FFFFFF
             主色调        #2563EB
             主色调浅      #DBEAFE
             主色调深      #1D4ED8
             文字主色      #0F172A
             文字次要      #475569
             文字浅灰      #94A3B8
             边框色        #E2E8F0
             成功绿        #10B981
             警告黄        #F59E0B
             危险红        #EF4444
        -->

        <!-- ============================================================ -->
        <!-- 通用样式                                                      -->
        <!-- ============================================================ -->

        <!-- 页面标题样式 -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 页面副标题 / 描述文本 -->
        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>

        <!-- 区块标题（卡片内使用） -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 表单标签 -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- 卡片容器 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- ============================================================ -->
        <!-- 导航按钮样式（含当前页面高亮）                                 -->
        <!-- ============================================================ -->

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 鼠标悬停效果 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
                <!-- 按下效果 -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CBD5E1"/>
                </Trigger>
                <!-- 页面激活高亮：由各按钮自身的 Style.Trigger + PageEqConverter 实现 -->
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!-- 操作按钮样式（主色蓝底白字）                                   -->
        <!-- ============================================================ -->

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式（白底灰边框） -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="BorderBrush" Value="#94A3B8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 成功按钮样式（绿色） -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#10B981"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 危险按钮样式（红色） -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#EF4444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!-- DataGrid 样式                                                  -->
        <!-- ============================================================ -->

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================ -->
        <!-- 通用 ComboBox 样式                                             -->
        <!-- ============================================================ -->

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>

        <!-- ============================================================ -->
        <!-- 通用 TextBox 样式                                              -->
        <!-- ============================================================ -->

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <!-- ============================================================ -->
        <!-- 通用 Slider 样式                                               -->
        <!-- ============================================================ -->

        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="1"/>
            <Setter Property="Maximum" Value="3"/>
            <Setter Property="TickFrequency" Value="0.1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- 分隔线样式 -->
        <Style x:Key="DividerStyle" TargetType="Rectangle">
            <Setter Property="Height" Value="2"/>
            <Setter Property="Fill" Value="#E2E8F0"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>
    </Window.Resources>

    <!-- ================================================================ -->
    <!-- 主布局：侧边栏 + 内容区                                            -->
    <!-- ================================================================ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!-- 左侧导航栏                                                      -->
        <!-- ============================================================ -->
        <Border Grid.Column="0"
                Background="#F1F5F9"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,1,0">
            <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 应用标题 -->
                <StackPanel Grid.Row="0" Margin="20,30,20,30">
                    <TextBlock Text="影音智增强"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="MediaEnhancer"
                               FontSize="11"
                               Foreground="#94A3B8"/>
                </StackPanel>

                <!-- 导航按钮列表 -->
                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                    <Button Content="📊  数据统计"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=0}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="📂  文件管理"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="1">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=1}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🔧  离线增强"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=2}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✨  实时增强"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="3">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=3}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⏺  屏幕录制"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=4}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="💬  AI 对话"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=5}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🎨  AI 编辑"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="6">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=6}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⚙  系统设置"
                            Command="{Binding ChangePageCommand}"
                            CommandParameter="7">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPageIndex, Converter={StaticResource PageEqConverter}, ConverterParameter=7}" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 底部用户信息 -->
                <StackPanel Grid.Row="2" Margin="20,0,20,16">
                    <Border Background="#E8F0FE" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Foreground="#2563EB" FontSize="11" FontWeight="SemiBold"
                                       Text="👤 当前用户"/>
                            <TextBlock Text="{Binding CurrentUserDisplayName}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#0F172A" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 版本信息 -->
                <TextBlock Grid.Row="3"
                           Text="{Binding AppVersion, StringFormat='版本 {0}'}"
                           FontSize="11"
                           Foreground="#94A3B8"
                           Margin="20,0,20,18"
                           HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- 右侧主内容区                                                    -->
        <!-- ============================================================ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="35,30,35,30">

                <!-- ==================================================== -->
                <!-- 页面 1：文件管理                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1}"
                      Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="我的影音库" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="管理本地的视频与图片文件，支持扫描导入、筛选搜索、收藏标记" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <!-- 工具栏 -->
                    <Border Grid.Row="1"
                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
                        <StackPanel>
                            <!-- 第一行：搜索 + 筛选 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0"
                                        BorderThickness="1" CornerRadius="6" Padding="10,0"
                                        Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0" Padding="0,7"
                                                 FontSize="13" Foreground="#0F172A"/>
                                    </Grid>
                                </Border>

                                <ComboBox Grid.Column="1" ItemsSource="{Binding TypeFilters}"
                                          SelectedItem="{Binding FilterType}"
                                          Style="{StaticResource ComboBoxStyle}" Margin="0,0,12,0"/>

                                <CheckBox Grid.Column="2" IsChecked="{Binding FilterFavoritesOnly}"
                                          Content="仅收藏" FontSize="13" Foreground="#475569"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <!-- 第二行：操作按钮 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="📁 选择文件夹"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding SelectFolderCommand}"
                                        Margin="0,0,8,0" Height="36"/>

                                <Button Grid.Column="1" Content="➕ 导入文件"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ImportFilesCommand}"
                                        Margin="4,0,8,0" Height="36"/>

                                <Button Grid.Column="2" Content="🗑 删除"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding DeleteFileCommand}"
                                        CommandParameter="{Binding SelectedFile}"
                                        Margin="4,0,8,0" Height="36"/>

                                <Button Grid.Column="3" Content="🔄 刷新"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding RefreshCommand}"
                                        Margin="4,0,8,0" Height="36"/>

                                <Button Grid.Column="4" Content="🔍 校验"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ValidateFilesCommand}"
                                        Margin="4,0,0,0" Height="36"/>
                            </Grid>

                            <!-- 扫描 / 增强状态提示 -->
                            <TextBlock Text="{Binding ScanProgress}" FontSize="12" Foreground="#2563EB"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding HasEnhanceProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding EnhanceProgress}" FontSize="12" Foreground="#7C3AED"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                                <Button Content="取消" Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding CancelEnhanceCommand}"
                                        Padding="6,2" FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- 批量操作栏 -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                               FontSize="12" Foreground="#64748B">
                                        <Run Text="批量操作  "/>
                                        <Run Text="{Binding SelectedFiles.Count, Mode=OneWay}"/>
                                        <Run Text=" 项选中"/>
                                    </TextBlock>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="⭐ 收藏" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding BatchToggleFavoriteCommand}"
                                                Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                                IsEnabled="{Binding HasMultipleSelected}"/>
                                        <Button Content="🗑 删除" Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding BatchDeleteCommand}"
                                                Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                                IsEnabled="{Binding HasMultipleSelected}"/>
                                        <Button Content="🖼 缩略图" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding BatchGenerateThumbnailsCommand}"
                                                Padding="8,4" FontSize="11"
                                                IsEnabled="{Binding HasMultipleSelected}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 主内容区：DataGrid + 浮层详情面板 -->
                    <Grid Grid.Row="3">

                        <!-- 底层：文件列表 DataGrid -->
                        <DataGrid x:Name="FileDataGrid"
                                  ItemsSource="{Binding MediaFilesList}"
                                  Style="{StaticResource DataGridStyle}"
                                  Margin="0,0,0,100"
                                  SelectionMode="Extended"
                                  SelectedItem="{Binding SelectedFile, UpdateSourceTrigger=PropertyChanged}"
                                  CellEditEnding="DataGrid_CellEditEnding"
                                  MouseDoubleClick="FileDataGrid_MouseDoubleClick"
                                  SelectionChanged="FileDataGrid_SelectionChanged">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}"/>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailConverter}}"
                                                   Width="40" Height="40" Stretch="Uniform"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="2*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="60" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="简介" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}"
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                       VerticalAlignment="Center" ToolTip="{Binding Description}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="导入时间" Binding="{Binding DateAdded, StringFormat=yyyy-MM-dd HH:mm}" Width="130" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="收藏" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsFavorite, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="播放" Binding="{Binding PlayCount}" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 浮层详情面板 -->
                        <Border HorizontalAlignment="Right" Width="350"
                                Background="White" BorderBrush="#CBD5E1" BorderThickness="1,0,0,1"
                                Visibility="{Binding ShowDetailPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="4" Color="#64748B" Opacity="0.25" BlurRadius="12" Direction="270"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 顶栏 -->
                                <Border Grid.Row="0" Background="#F8FAFC"
                                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                        Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SelectedFile.Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#0F172A" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" Content="X"
                                                Width="28" Height="28" Background="Transparent"
                                                Foreground="#64748B" BorderThickness="0"
                                                Cursor="Hand" FontSize="14" ToolTip="关闭"
                                                Command="{Binding CloseDetailPanelCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- 内容区 -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                                    <StackPanel>

                                        <!-- 缩略图 + 基本信息 -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                                            <StackPanel>
                                                <Border Background="#F1F5F9" CornerRadius="6"
                                                        Height="130" Margin="0,0,0,10">
                                                    <Image Source="{Binding SelectedFile.ThumbnailPath, Converter={StaticResource ThumbnailConverter}}"
                                                           MaxWidth="140" MaxHeight="130" Stretch="Uniform"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- 关键信息行 -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding SelectedFile.Type}"
                                                               FontSize="16" FontWeight="Bold" Foreground="#2563EB"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontSize="12" Foreground="#475569">
                                                            <Run Text="{Binding SelectedFile.FileFormat, Mode=OneWay}"/><Run Text="  ·  "/>
                                                            <Run Text="{Binding SelectedFile.FileSizeDisplay, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="12" Foreground="#475569" Margin="0,2,0,0">
                                                            <Run Text="{Binding SelectedFile.Width, Mode=OneWay}"/>
                                                            <Run Text=" x "/>
                                                            <Run Text="{Binding SelectedFile.Height, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="12" Foreground="#475569" Margin="0,2,0,0"
                                                                   Text="{Binding SelectedFile.Duration, StringFormat='⏱ {0}'}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- 收藏 + 播放 -->
                                                <Grid Margin="0,10,0,0">
                                                    <CheckBox IsChecked="{Binding SelectedFile.IsFavorite}"
                                                              Content="收藏" FontSize="13" Foreground="#475569"
                                                              HorizontalAlignment="Left"
                                                              Command="{Binding ToggleFavoriteCommand}"
                                                              CommandParameter="{Binding SelectedFile}"/>
                                                    <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="#64748B">
                                                        <Run Text="▶ 播放 "/><Run Text="{Binding SelectedFile.PlayCount}"/><Run Text=" 次"/>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- 简介 -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="简介" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBox Text="{Binding SelectedFile.Description, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource TextBoxStyle}" AcceptsReturn="True"
                                                         TextWrapping="Wrap" MinHeight="50" MaxLines="4" Margin="0,0,0,8"/>
                                                <Button Content="💾 保存" Style="{StaticResource PrimaryButtonStyle}"
                                                        Command="{Binding SaveDescriptionCommand}"
                                                        CommandParameter="{Binding SelectedFile}"
                                                        HorizontalAlignment="Right" Height="28" FontSize="12" Padding="10,3"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 操作按钮 -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                                            <StackPanel>
                                                <Button Content="▶ 播放" Style="{StaticResource PrimaryButtonStyle}"
                                                        Command="{Binding PlayFileCommand}" CommandParameter="{Binding SelectedFile}"
                                                        HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="36" FontSize="14"/>
                                                <Button Content="✨ 增强" Style="{StaticResource PrimaryButtonStyle}"
                                                        Command="{Binding EnhanceFileCommand}" CommandParameter="{Binding SelectedFile}"
                                                        IsEnabled="{Binding IsEnhancing, Converter={StaticResource InvertBoolConverter}}"
                                                        HorizontalAlignment="Stretch" Margin="0,0,0,6" Height="36" FontSize="14"/>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="✏ 重命名"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding RenameFileCommand}"
                                                            CommandParameter="{Binding SelectedFile}"
                                                            Height="32" FontSize="12" Margin="0,0,4,0"/>
                                                    <Button Grid.Column="1" Content="🖼 缩略图"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding SetThumbnailCommand}"
                                                            CommandParameter="{Binding SelectedFile}"
                                                            Height="32" FontSize="12" Margin="4,0,0,0"/>
                                                </Grid>
                                                <Button Content="🗑 删除" Style="{StaticResource DangerButtonStyle}"
                                                        Command="{Binding DeleteFileCommand}" CommandParameter="{Binding SelectedFile}"
                                                        HorizontalAlignment="Stretch" Height="32" FontSize="12"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 路径 + 时间 -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="文件路径" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBox Text="{Binding SelectedFile.FilePath, Mode=OneWay}"
                                                         FontSize="12" Foreground="#475569"
                                                         Background="Transparent" BorderThickness="0"
                                                         IsReadOnly="True" TextWrapping="Wrap" Padding="0"/>
                                                <Rectangle Style="{StaticResource DividerStyle}" Margin="0,8"/>
                                                <TextBlock FontSize="12" Foreground="#475569" Margin="0,0,0,2">
                                                    <Run Text="导入时间：" Foreground="#94A3B8"/>
                                                    <Run Text="{Binding SelectedFile.DateAdded, StringFormat='yyyy-MM-dd HH:mm', Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="#475569">
                                                    <Run Text="修改时间：" Foreground="#94A3B8"/>
                                                    <Run Text="{Binding SelectedFile.DateModified, StringFormat='yyyy-MM-dd HH:mm', Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                        <!-- 底部留白，确保最后一张卡片内容不被截断 -->
                                        <Rectangle Height="40"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 3：实时增强                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=3}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="实时增强" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="对任意屏幕内容进行低延迟实时画面增强，支持多种增强方法与参数调节" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <!-- 单列控制区布局 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="500"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 控制区（居中） -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- 增强开关 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="增强控制" Style="{StaticResource SectionTitleStyle}"/>

                                        <!-- 开关按钮 -->
                                        <Button Height="42"
                                                FontSize="15"
                                                FontWeight="SemiBold">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                    <Setter Property="Content" Value="▶ 开启全屏增强"/>
                                                    <Setter Property="Command" Value="{Binding StartFullscreenEnhanceCommand}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnhancementEnabled}" Value="True">
                                                            <Setter Property="Content" Value="⏹ 停止全屏增强 (F11)"/>
                                                            <Setter Property="Command" Value="{Binding StopFullscreenEnhanceCommand}"/>
                                                            <Setter Property="Background" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnhancing}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRealTimeMethodSelected}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Content" Value="⛔ 该方法不支持实时增强"/>
                                                            <Setter Property="ToolTip" Value="请切换到支持实时的增强方法（如线性拉伸或 Multinex Nano）"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 方法选择 -->
                                        <TextBlock Text="增强方法" Style="{StaticResource FormLabelStyle}" Margin="0,16,0,0"/>
                                        <ComboBox ItemsSource="{Binding EnhancementMethods}"
                                                  SelectedItem="{Binding SelectedMethod}"
                                                  Style="{StaticResource ComboBoxStyle}"/>
                                        <TextBlock Margin="0,4,0,0" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⚡ 支持实时增强"/>
                                                    <Setter Property="Foreground" Value="#059669"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRealTimeMethodSelected}" Value="False">
                                                            <Setter Property="Text" Value="⏳ 仅离线增强（全屏不可用）"/>
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Visibility="{Binding IsLinearStretchSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Rectangle Style="{StaticResource DividerStyle}"/>

                                        <!-- 参数调节 -->
                                        <TextBlock Text="对比度强度" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Value="{Binding LinearStretch.Contrast}"
                                                    Minimum="0.5" Maximum="2.0"
                                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                    Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LinearStretch.Contrast, StringFormat=F1}"
                                                       FontSize="13" Foreground="#475569"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>

                                        <TextBlock Text="亮度偏移" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Value="{Binding LinearStretch.Brightness}"
                                                    Minimum="-50" Maximum="50"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LinearStretch.Brightness, StringFormat=F0}"
                                                       FontSize="13" Foreground="#475569"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>

                                <!-- 实时增强会话记录 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="使用记录" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock FontSize="12" Foreground="#94A3B8" Margin="0,0,0,12"
                                                   Text="实时全屏增强会话记录"/>

                                        <ItemsControl ItemsSource="{Binding RealtimeSessions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,6" Margin="0,0,0,4"
                                                            Background="#F8FAFC" CornerRadius="6"
                                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="#2563EB"
                                                                           Text="{Binding MethodName}"/>
                                                                <TextBlock FontSize="11" Foreground="#94A3B8"
                                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                                           Text="{Binding StartedAt, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                                            </StackPanel>
                                                            <TextBlock FontSize="11" Foreground="#64748B"
                                                                       Margin="0,2,0,0"
                                                                       Text="{Binding DurationText}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 空状态 -->
                                        <TextBlock Text="暂无使用记录"
                                                   FontSize="13" Foreground="#94A3B8"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRealtimeSessions}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 4：屏幕录制                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=4}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="屏幕录制" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="录制全屏画面，支持增强录制。音频功能暂未实现。" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧控制区 -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,20,0">

                                <!-- 录制源选择 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="录制源" Style="{StaticResource SectionTitleStyle}"/>

                                        <TextBlock Text="录制范围：全屏"
                                                   FontSize="13" Foreground="#475569"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="音频选项" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBlock Text="暂不支持（未来功能）"
                                                   FontSize="12" Foreground="#94A3B8"
                                                   Margin="0,0,0,8"/>
                                    </StackPanel>
                                </Border>

                                <!-- 录制控制 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="录制控制" Style="{StaticResource SectionTitleStyle}"/>

                                        <!-- 录制状态指示器 -->
                                        <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 第一行：状态文本 -->
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#94A3B8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding RecordingStatus}"/>
                                                                <Setter Property="FontSize" Value="13"/>
                                                                <Setter Property="Foreground" Value="#475569"/>
                                                                <Setter Property="MaxWidth" Value="280"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                                        <Setter Property="Foreground" Value="#7F1D1D"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- 第二行：时长 / 取消按钮 -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding RecordingDuration}"
                                                               FontSize="16" FontWeight="Bold"
                                                               Foreground="#DC2626"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <Button Content="✕ 取消增强"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding CancelRecordingEnhancementCommand}"
                                                            Padding="6,2" FontSize="11" Height="24"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsProcessingRecording, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- 录制按钮 -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Content="⏺ 开始"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Command="{Binding StartRecordingCommand}"
                                                    IsEnabled="{Binding CanStartRecording}"
                                                    Margin="0,0,6,0"
                                                    Height="38"/>
                                            <Button Grid.Column="1"
                                                    Content="⏹ 停止"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding StopRecordingCommand}"
                                                    IsEnabled="{Binding IsRecording}"
                                                    Margin="6,0,0,0"
                                                    Height="38"/>
                                        </Grid>

                                        <!-- 增强录制开关 -->
                                        <CheckBox IsChecked="{Binding EnhancedRecording}"
                                                  Content="增强录制（应用当前增强效果）"
                                                  FontSize="13"
                                                  Foreground="#475569"
                                                  Margin="0,4,0,0"/>
                                        <TextBlock FontSize="11" Foreground="#94A3B8"
                                                   Margin="20,4,0,0" TextWrapping="Wrap"
                                                   Visibility="{Binding EnhancedRecording, Converter={StaticResource BoolToVisibilityConverter}}">
                                            💡 增强算法在「离线增强」页面中设置，当前方法：<Run Text="{Binding SelectedOfflineMethodName, Mode=OneWay}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 操作按钮 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Button Content="📂 打开录制文件夹"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding OpenRecordingFolderCommand}"
                                            HorizontalAlignment="Stretch"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 分隔线 -->
                        <Rectangle Grid.Column="1" Width="1" Fill="#E2E8F0"/>

                        <!-- 右侧录制列表 -->
                        <Border Grid.Column="2"
                                Style="{StaticResource CardStyle}"
                                Margin="20,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="录制历史"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <!-- 录制历史列表 -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Recordings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" Margin="0,0,0,4"
                                                        Background="#F8FAFC" CornerRadius="6"
                                                        BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding MediaFile.Title}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#0F172A"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="  [增强]"
                                                                       FontSize="11" Foreground="#2563EB"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding IsEnhanced, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding Duration}"
                                                                       FontSize="12" Foreground="#64748B"/>
                                                            <TextBlock Text=" · " FontSize="12" Foreground="#94A3B8"/>
                                                            <TextBlock Text="{Binding FileSizeDisplay}"
                                                                       FontSize="12" Foreground="#64748B"/>
                                                            <TextBlock Text=" · " FontSize="12" Foreground="#94A3B8"/>
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                                       FontSize="12" Foreground="#94A3B8"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 5：AI 对话                                          -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=5}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <StackPanel Grid.Row="0" Margin="35,30,35,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AI 对话" Style="{StaticResource PageTitleStyle}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ChatConfigured}" Value="True">
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ChatStatusText}" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="🗑 清空" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ClearAiChatCommand}"
                                    Height="32" FontSize="12" Padding="10,4" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>

                    <!-- 消息列表（全宽） -->
                    <ScrollViewer Grid.Row="1" x:Name="AiChatScroller"
                                  VerticalScrollBarVisibility="Auto" Padding="35,0">
                        <ItemsControl ItemsSource="{Binding AiMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,20">
                                        <!-- AI / thinking：头像在左 -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*" MaxWidth="650"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                    VerticalAlignment="Top" Margin="0,0,12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="thinking">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="🤖"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="thinking">
                                                                    <Setter Property="Text" Value="⏳"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="AI 助手"/>
                                                            <Setter Property="Foreground" Value="#2563EB"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="thinking">
                                                                    <Setter Property="Text" Value="正在思考"/>
                                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Background="White" BorderBrush="#E2E8F0"
                                                        BorderThickness="1" CornerRadius="12" Padding="16,12">
                                                    <StackPanel>
                                                        <ContentControl Content="{Binding Content, Converter={StaticResource MarkdownTextConverter}}"/>
                                                        <TextBlock Margin="0,8,0,0">
                                                            <Hyperlink Click="CopyMessage_Click" Tag="{Binding Content}"
                                                                       Foreground="#94A3B8" FontSize="11" TextDecorations="None">📋 复制</Hyperlink>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 用户：右对齐 -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                <StackPanel MaxWidth="450">
                                                    <TextBlock Text="你" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#64748B" HorizontalAlignment="Right"
                                                               Margin="0,0,12,4"/>
                                                    <Border Background="#DBEAFE" BorderBrush="#BFDBFE"
                                                            BorderThickness="1" CornerRadius="12" Padding="16,12">
                                                        <StackPanel>
                                                            <ContentControl Content="{Binding Content, Converter={StaticResource MarkdownTextConverter}}"/>
                                                            <!-- 附件缩略图 -->
                                                            <ItemsControl ItemsSource="{Binding AttachmentPaths}" Margin="0,8,0,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Image Source="{Binding Converter={StaticResource ThumbnailConverter}}"
                                                                               Width="64" Height="64" Stretch="UniformToFill"
                                                                               Margin="0,0,4,4" RenderOptions.BitmapScalingMode="LowQuality"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Right">
                                                                <Hyperlink Click="CopyMessage_Click" Tag="{Binding Content}"
                                                                           Foreground="#94A3B8" FontSize="11" TextDecorations="None">📋 复制</Hyperlink>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <Border Width="32" Height="32" CornerRadius="16"
                                                        Background="#E2E8F0" VerticalAlignment="Top"
                                                        Margin="12,0,0,0">
                                                    <TextBlock Text="👤" FontSize="14"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 底部输入 + 预设 -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <StackPanel Margin="35,12,35,12">
                            <!-- 输入行 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="FileDropdownBtn" Grid.Column="0" Content="＋"
                                        Width="38" Height="38" FontSize="20" FontWeight="Bold"
                                        Foreground="#64748B" Background="#F1F5F9"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="FileDropdown_Click" ToolTip="选择上下文文件"
                                        VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Margin="6,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="12" Foreground="#64748B"
                                           Text="{Binding SelectedAiFileCount, StringFormat='已选 {0}'}"/>

                                <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#CBD5E1"
                                        BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding AiInputText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="14,10" BorderThickness="0" Background="Transparent"
                                             FontSize="14" Foreground="#0F172A"
                                             VerticalContentAlignment="Center"
                                             KeyDown="AiInput_KeyDown"/>
                                </Border>

                                <Button Grid.Column="3" Content="发送" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SendAiMessageCommand}"
                                        Width="64" Height="38" Margin="8,0,0,0"
                                        FontSize="13" FontWeight="SemiBold"/>
                            </Grid>

                            <Popup x:Name="FilePopup" PlacementTarget="{Binding ElementName=FileDropdownBtn}"
                                   Placement="Top" HorizontalOffset="0" Width="260" MaxHeight="350"
                                   StaysOpen="False" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                        CornerRadius="10" Padding="10" MaxHeight="350">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="4" Color="#000000" Opacity="0.12" BlurRadius="12"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="选择上下文文件" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#475569"
                                                   Margin="4,0,0,8"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding MediaFilesList}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{Binding Title}" FontSize="12"
                                                                  Foreground="#475569" Margin="2,3"
                                                                  Checked="FileCheckBox_Changed"
                                                                  Unchecked="FileCheckBox_Changed"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!-- 预设快捷操作 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="📝 AI 简介" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ApplyAiPresetCommand}" CommandParameter="简介"
                                        Height="28" FontSize="12" Padding="8,4" Margin="0,0,8,0"/>
                                <Button Content="📊 数据摘要" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ApplyAiPresetCommand}" CommandParameter="数据"
                                        Height="28" FontSize="12" Padding="8,4" Margin="0,0,8,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ==================================================== -->
                <!-- ==================================================== -->
                <!-- 页面 6：AI 编辑                                          -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=6}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="AI 图像编辑" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="选择图片，输入自然语言描述，AI 自动增强、美化或生成新图像" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧控制面板 -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,15,0">

                                <!-- 图片选择 -->
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="参考图片（可选）" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock Text="不选图片则生成新图像" FontSize="11"
                                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                                        <Button Content="📁 浏览本地图片…" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding AiEditSelectFileCommand}"
                                                HorizontalAlignment="Stretch" Height="34" Margin="0,0,0,8"/>
                                        <Grid Visibility="{Binding HasEditImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding AiEditFiles[0].Title}"
                                                       FontSize="12" Foreground="#64748B"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                                    Background="Transparent" Foreground="#EF4444"
                                                    BorderThickness="0" Cursor="Hand" FontSize="12"
                                                    Command="{Binding AiEditClearFileCommand}"
                                                    ToolTip="取消选择"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 原图预览 -->
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="原图" Style="{StaticResource SectionTitleStyle}"/>
                                        <Border Background="#F1F5F9" CornerRadius="8" MinHeight="180"
                                                HorizontalAlignment="Stretch">
                                            <Image Source="{Binding AiEditOriginal}" Stretch="Uniform"
                                                   MaxWidth="280" MaxHeight="240"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 使用提示 -->
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="💡 使用方法" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock FontSize="12" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,4"
                                                   Text="• 选图 + 描述 → AI 编辑图像（增强、美化、修复）"/>
                                        <TextBlock FontSize="12" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,4"
                                                   Text="• 只写描述 → AI 文生图（需用文生图模型）"/>
                                        <TextBlock FontSize="12" Foreground="#475569" TextWrapping="Wrap"
                                                   Text="• 模型含 Edit 字样 → 必须选图，否则报错"/>
                                    </StackPanel>
                                </Border>

                                <!-- 提示词 -->
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="增强描述" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock Text="用自然语言描述你想要的增强效果" FontSize="12"
                                                   Foreground="#94A3B8" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        <TextBox Text="{Binding AiEditPrompt, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TextBoxStyle}"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MinHeight="80" MaxLines="4"
                                                 ToolTip="例如：提升画面亮度，去除噪点，增强对比度"/>
                                        <Button Content="🚀 开始生成" Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding AiEditGenerateCommand}"
                                                HorizontalAlignment="Stretch" Height="40" FontSize="14"
                                                FontWeight="SemiBold" Margin="0,12,0,0"/>
                                        <TextBlock Text="{Binding AiEditStatus}" FontSize="12"
                                                   Foreground="#64748B" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- API 提示（未配置时） -->
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="💡 提示" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#2563EB" Margin="0,0,0,6"/>
                                        <TextBlock Text="本功能需要配置 API 才能使用。前往 系统设置 → AI 设置 填入阿里百炼 API Key。"
                                                   FontSize="12" Foreground="#475569" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Rectangle Grid.Column="1" Width="1" Fill="#E2E8F0"/>

                        <!-- 右侧结果区 -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="15,0,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="生成结果" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="💾 保存" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding AiEditSaveCommand}"
                                            Padding="8,4" FontSize="11" ToolTip="保存图片"/>
                                </Grid>

                                <!-- 加载动画 -->
                                <Border Background="#FFF7ED" CornerRadius="8" Padding="16,12"
                                        Visibility="{Binding AiEditGenerating, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBlock Text="AI 正在生成图像…" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#92400E"/>
                                            <TextBlock Text="这可能需要 10-30 秒，请耐心等待" FontSize="12"
                                                       Foreground="#A16207"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 结果 -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                              MaxHeight="800">
                                    <Image Source="{Binding AiEditResult}" Stretch="Uniform" MinHeight="300"/>
                                </ScrollViewer>

                                <!-- 空状态 -->
                                <TextBlock Text="选择图片并描述增强效果，点击生成即可查看结果"
                                           FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"
                                           Margin="0,20,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AiEditResult}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 7：系统设置                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=7}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="系统设置" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="配置 AI 服务、增强参数预设、性能选项等系统全局设置" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左列设置项 -->
                            <StackPanel Grid.Column="0">

                                <!-- AI 对话设置 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#94A3B8"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ChatConfigured}" Value="True">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="AI 对话" Style="{StaticResource SectionTitleStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="API 请求地址" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding ApiEndpointPresets}"
                                                  Text="{Binding ChatApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,10"/>
                                        <TextBlock Text="API 密钥" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="ChatApiKeyBox"
                                                         PasswordChanged="ChatApiKeyBox_PasswordChanged"
                                                         PasswordChar="●"
                                                         Padding="10,6" FontSize="13"
                                                         Background="White"
                                                         BorderBrush="#CBD5E1"
                                                         BorderThickness="2"/>
                                            <TextBox x:Name="ChatApiKeyTextBox"
                                                     Text="{Binding ChatApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="10,6" FontSize="13"
                                                     Background="White"
                                                     BorderBrush="#CBD5E1"
                                                     BorderThickness="2"
                                                     Visibility="Collapsed"/>
                                            <Button Grid.Column="1" Content="👁" Width="36" Height="36"
                                                    Margin="4,0,0,0" Padding="4" FontSize="14"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="ToggleChatApiKeyVisibility_Click"/>
                                        </Grid>
                                        <TextBlock Text="模型名称" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding ChatModelName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TextBoxStyle}" ToolTip="qwen-plus, qwen-max 等" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </Border>

                                <!-- AI 编辑（生图）设置 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#94A3B8"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EditConfigured}" Value="True">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="AI 编辑（生图）" Style="{StaticResource SectionTitleStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="API 端点" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding EditApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TextBoxStyle}" Margin="0,0,0,10"/>
                                        <TextBlock Text="API 密钥" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="EditApiKeyBox"
                                                         PasswordChanged="EditApiKeyBox_PasswordChanged"
                                                         PasswordChar="●"
                                                         Padding="10,6" FontSize="13"
                                                         Background="White"
                                                         BorderBrush="#CBD5E1"
                                                         BorderThickness="2"/>
                                            <TextBox x:Name="EditApiKeyTextBox"
                                                     Text="{Binding EditApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="10,6" FontSize="13"
                                                     Background="White"
                                                     BorderBrush="#CBD5E1"
                                                     BorderThickness="2"
                                                     Visibility="Collapsed"/>
                                            <Button Grid.Column="1" Content="👁" Width="36" Height="36"
                                                    Margin="4,0,0,0" Padding="4" FontSize="14"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="ToggleEditApiKeyVisibility_Click"/>
                                        </Grid>
                                        <TextBlock Text="模型名称" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding EditModelName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TextBoxStyle}" ToolTip="wanx2.0-t2i-turbo 等" Margin="0,0,0,10"/>
                                        <TextBlock Text="API 格式" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding EditFormatOptions}"
                                                  SelectedItem="{Binding EditFormat, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </Border>

                                <!-- 性能设置 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="性能设置" Style="{StaticResource SectionTitleStyle}"/>

                                        <TextBlock Text="运算设备" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding DeviceOptions}"
                                                  SelectedItem="{Binding SelectedDevice}"
                                                  Style="{StaticResource ComboBoxStyle}"
                                                  IsEnabled="False"
                                                  ToolTip="当前仅支持 CPU 运算"
                                                  Margin="0,0,0,4"/>
                                    </StackPanel>
                                </Border>

                                <!-- 保存路径 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="保存路径" Style="{StaticResource SectionTitleStyle}"/>

                                        <TextBlock Text="录屏文件保存目录" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding RecordingSavePath, Mode=OneWay}"
                                                     Style="{StaticResource TextBoxStyle}" IsReadOnly="True"
                                                     ToolTip="录屏生成的 MP4 文件存放位置"/>
                                            <Button Grid.Column="1" Content="📂" Width="36" Height="36"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding BrowseRecordingPathCommand}"
                                                    Margin="6,0,0,0" Padding="6,4" FontSize="14"/>
                                        </Grid>

                                        <TextBlock Text="增强结果保存目录" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding EnhancementSavePath, Mode=OneWay}"
                                                     Style="{StaticResource TextBoxStyle}" IsReadOnly="True"
                                                     ToolTip="增强处理后的文件存放位置"/>
                                            <Button Grid.Column="1" Content="📂" Width="36" Height="36"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding BrowseEnhancementPathCommand}"
                                                    Margin="6,0,0,0" Padding="6,4" FontSize="14"/>
                                        </Grid>

                                        <TextBlock Text="缩略图缓存目录" Style="{StaticResource FormLabelStyle}"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding ThumbnailSavePath, Mode=OneWay}"
                                                     Style="{StaticResource TextBoxStyle}" IsReadOnly="True"
                                                     ToolTip="缩略图缓存文件存放位置"/>
                                            <Button Grid.Column="1" Content="📂" Width="36" Height="36"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding BrowseThumbnailPathCommand}"
                                                    Margin="6,0,0,0" Padding="6,4" FontSize="14"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 右列设置项 -->
                            <StackPanel Grid.Column="2">

                                <!-- 系统操作 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="系统操作" Style="{StaticResource SectionTitleStyle}"/>
                                        <Button Content="💾 保存所有设置"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding SaveSettingsCommand}"
                                                HorizontalAlignment="Stretch"
                                                Height="38"
                                                FontWeight="SemiBold"/>
                                        <Button Content="↺ 重置所有设置到默认值"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ResetAllSettingsCommand}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 2：离线增强                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=2}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="离线增强" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="选择方法、预览效果、增强并导出图片" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <!-- 三列布局：方法选择 | 预览区 | 使用说明 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左列：方法选择 -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="增强方法" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock Text="选择用于离线增强的深度学习算法"
                                                   FontSize="13" Foreground="#64748B" Margin="0,0,0,12"/>

                                        <TextBlock Text="当前方法" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding OfflineEnhancementMethods}"
                                                  SelectedItem="{Binding SelectedOfflineMethodName}"
                                                  Style="{StaticResource ComboBoxStyle}"
                                                  Margin="0,0,0,12"/>

                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="方法说明" Margin="0,16,0,8"/>
                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="14,12">
                                            <TextBlock FontSize="13" Foreground="#475569" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="请从上方下拉框选择增强方法，然后在文件管理中右键文件 → 增强即可。"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedOfflineMethodName}" Value="线性拉伸">
                                                                <Setter Property="Text" Value="线性拉伸：像素值线性映射到全动态范围，无额外依赖，极速处理。适合轻度增强场景。"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedOfflineMethodName}" Value="Multinex Nano 低光增强">
                                                                <Setter Property="Text" Value="Multinex Nano：超轻量 Retinex 网络（15K 参数），LOL-v2 合成数据训练。速度最快，适合批量处理和视频增强。"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- 线性拉伸参数（仅选中时显示） -->
                                        <Border Style="{StaticResource CardStyle}"
                                                Visibility="{Binding IsLinearStretchSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="参数调节" Style="{StaticResource SectionTitleStyle}"/>

                                                <TextBlock Text="对比度强度" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Grid.Column="0"
                                                            Value="{Binding LinearStretch.Contrast}"
                                                            Minimum="0.5" Maximum="2.0"
                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                            Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding LinearStretch.Contrast, StringFormat=F1}"
                                                               FontSize="13" Foreground="#475569"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>

                                                <TextBlock Text="亮度偏移" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Grid.Column="0"
                                                            Value="{Binding LinearStretch.Brightness}"
                                                            Minimum="-50" Maximum="50"
                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                            Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding LinearStretch.Brightness, StringFormat=F0}"
                                                               FontSize="13" Foreground="#475569"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 中列：预览区 -->
                        <Border Grid.Column="1"
                                Style="{StaticResource CardStyle}"
                                Margin="10,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="增强预览"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <Border Grid.Row="1"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,10">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <Image Source="{Binding EnhancedPreview}"
                                                   Stretch="Uniform"
                                                   MaxWidth="500" MaxHeight="400"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <!-- 增强预览加载中的提示 -->
                                            <Border Background="#F8FAFC" CornerRadius="8" Padding="24,16"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <!-- 进度非空 且 预览为空时显示 -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding HasEnhanceProgress}" Value="True"/>
                                                                    <Condition Binding="{Binding EnhancedPreview}" Value="{x:Null}"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="⏳" FontSize="32"
                                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                    <TextBlock Text="{Binding EnhanceProgress}" FontSize="14"
                                                               Foreground="#7C3AED" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="增强处理中，请耐心等待…" FontSize="12"
                                                               Foreground="#94A3B8"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>

                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Button Content="📷 选择图片"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding PreviewEnhancementCommand}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="📥 导出增强图"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding ExportEnhancedCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 右列：使用说明 -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="使用方式" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock FontSize="13" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,16"
                                                   Text="离线增强作用于以下场景：" LineHeight="20"/>

                                        <Border Background="#F0FDF4" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="📁 单张图片增强" FontSize="13" FontWeight="SemiBold" Foreground="#166534"/>
                                                <TextBlock Text="文件管理 → 选中文件 → 详情面板 → 增强" FontSize="12" Foreground="#15803D" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#EFF6FF" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="📚 批量图片增强" FontSize="13" FontWeight="SemiBold" Foreground="#1E40AF"/>
                                                <TextBlock Text="文件管理 → 多选文件 → 底部批量工具栏 → 增强" FontSize="12" Foreground="#2563EB" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FEF3C7" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="🎬 视频逐帧增强" FontSize="13" FontWeight="SemiBold" Foreground="#92400E"/>
                                                <TextBlock Text="文件管理 → 选中视频 → 详情面板 → 增强" FontSize="12" Foreground="#B45309" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Rectangle Style="{StaticResource DividerStyle}"/>

                                        <TextBlock Text="💡 提示" FontSize="13" FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,6"/>
                                        <TextBlock FontSize="12" Foreground="#6D28D9" TextWrapping="Wrap"
                                                   Text="• 深度学习增强耗时较长，视频增强请耐心等待&#x0a;• 实时全屏增强请前往「实时增强」页面，仅支持轻量级方法"/>
                                    </StackPanel>
                                </Border>

                                <!-- 增强历史记录 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="增强记录" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock FontSize="12" Foreground="#94A3B8" Margin="0,0,0,12"
                                                   Text="最近 50 条增强历史"/>

                                        <!-- 记录列表 -->
                                        <ItemsControl ItemsSource="{Binding EnhancementLogs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,6" Margin="0,0,0,4"
                                                            Background="#F8FAFC" CornerRadius="6"
                                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                                        <StackPanel>
                                                            <!-- 方法名 + 时间 -->
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="#7C3AED"
                                                                           Text="{Binding MethodName}"/>
                                                                <TextBlock FontSize="11" Foreground="#94A3B8"
                                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                                           Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                                            </StackPanel>
                                                            <!-- 源文件 -->
                                                            <TextBlock FontSize="11" Foreground="#64748B"
                                                                       Margin="0,2,0,0"
                                                                       TextTrimming="CharacterEllipsis">
                                                                <Run Text="源文件："/>
                                                                <Run Text="{Binding MediaFile.Title}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 空状态 -->
                                        <TextBlock Text="暂无增强记录"
                                                   FontSize="13" Foreground="#94A3B8"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasEnhancementLogs}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ==================================================== -->
                <!-- 页面 0：数据统计                                        -->
                <!-- ==================================================== -->
                <Grid Visibility="{Binding SelectedPageIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 页面标题 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="数据统计" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="一览系统中的媒体资源与功能使用情况" Style="{StaticResource PageSubtitleStyle}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- 统计卡片网格：3列3行 -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 卡片1：文件总数 -->
                                <Border Grid.Row="0" Grid.Column="0"
                                        Style="{StaticResource CardStyle}"
                                        Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="📁" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding TotalFileCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="文件总数" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片2：图片数量 -->
                                <Border Grid.Row="0" Grid.Column="1"
                                        Style="{StaticResource CardStyle}"
                                        Margin="5,0,5,10">
                                    <StackPanel>
                                        <TextBlock Text="🖼" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding ImageCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#2563EB"/>
                                        <TextBlock Text="图片数量" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片3：视频数量 -->
                                <Border Grid.Row="0" Grid.Column="2"
                                        Style="{StaticResource CardStyle}"
                                        Margin="10,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="🎬" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding VideoCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#059669"/>
                                        <TextBlock Text="视频数量" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片4：音频数量 -->
                                <Border Grid.Row="1" Grid.Column="0"
                                        Style="{StaticResource CardStyle}"
                                        Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="🎵" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding AudioCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#8B5CF6"/>
                                        <TextBlock Text="音频数量" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片5：实时增强次数 -->
                                <Border Grid.Row="1" Grid.Column="1"
                                        Style="{StaticResource CardStyle}"
                                        Margin="5,0,5,10">
                                    <StackPanel>
                                        <TextBlock Text="🔍" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding RealtimeEnhanceCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#D97706"/>
                                        <TextBlock Text="实时增强使用" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片6：录屏次数 -->
                                <Border Grid.Row="1" Grid.Column="2"
                                        Style="{StaticResource CardStyle}"
                                        Margin="10,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="⏺" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding RecordingCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#DC2626"/>
                                        <TextBlock Text="录屏次数" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片7：总播放次数 -->
                                <Border Grid.Row="2" Grid.Column="0"
                                        Style="{StaticResource CardStyle}"
                                        Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="▶" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding TotalPlayCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#0891B2"/>
                                        <TextBlock Text="总播放次数" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片8：收藏数 -->
                                <Border Grid.Row="2" Grid.Column="1"
                                        Style="{StaticResource CardStyle}"
                                        Margin="5,0,5,10">
                                    <StackPanel>
                                        <TextBlock Text="⭐" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding FavoriteCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#D97706"/>
                                        <TextBlock Text="收藏数" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 卡片9：增强次数 -->
                                <Border Grid.Row="2" Grid.Column="2"
                                        Style="{StaticResource CardStyle}"
                                        Margin="10,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="✨" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding EnhancementCount}"
                                                   FontSize="36" FontWeight="Bold" Foreground="#7C3AED"/>
                                        <TextBlock Text="文件增强次数" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- 快捷操作区 -->
                            <Border Style="{StaticResource CardStyle}" Padding="20,16">
                                <StackPanel>
                                    <TextBlock Text="⚡ 快速入口" FontSize="15" FontWeight="SemiBold"
                                               Foreground="#0F172A" Margin="0,0,0,12"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Row="0" Grid.Column="0" Content="📂 文件管理"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="1"
                                                Margin="0,0,6,6" Height="36"/>
                                        <Button Grid.Row="0" Grid.Column="1" Content="🔧 离线增强"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="2"
                                                Margin="3,0,6,6" Height="36"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="✨ 实时增强"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="3"
                                                Margin="3,0,6,6" Height="36"/>
                                        <Button Grid.Row="0" Grid.Column="3" Content="⏺ 屏幕录制"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="4"
                                                Margin="3,0,0,6" Height="36"/>

                                        <Button Grid.Row="1" Grid.Column="0" Content="💬 AI 对话"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="5"
                                                Margin="0,0,6,0" Height="36"/>
                                        <Button Grid.Row="1" Grid.Column="1" Content="🎨 AI 编辑"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="6"
                                                Margin="3,0,6,0" Height="36"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="⚙ 系统设置"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ChangePageCommand}" CommandParameter="7"
                                                Margin="3,0,6,0" Height="36"/>
                                        <Button Grid.Row="1" Grid.Column="3" Content="🔄 刷新"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding RefreshCommand}"
                                                Margin="3,0,0,0" Height="36"/>
                                    </Grid>

                                    <Rectangle Style="{StaticResource DividerStyle}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="📦 检查依赖"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding CheckDependenciesCommand}"
                                                Margin="0,0,8,0" Height="32" FontSize="12" Padding="10,4"/>
                                        <Button Content="🗑 清理缓存"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ClearThumbnailCacheCommand}"
                                                Height="32" FontSize="12" Padding="10,4"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 最近播放 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⏱ 最近播放" FontSize="15" FontWeight="SemiBold"
                                               Foreground="#0F172A" Margin="0,0,0,12"/>

                                    <!-- 最近播放列表 -->
                                    <ItemsControl ItemsSource="{Binding RecentPlays}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Margin="0,0,0,4"
                                                        Background="#F8FAFC" CornerRadius="6"
                                                        BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding MediaFile.Type, StringFormat={}{0}}"
                                                                   FontSize="12" Foreground="#64748B"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MediaFile.Title}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#0F172A"/>
                                                            <TextBlock Text="{Binding PlayedAt, StringFormat=yyyy-MM-dd HH:mm}"
                                                                       FontSize="11" Foreground="#94A3B8"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2" Content="▶"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Command="{Binding DataContext.PlayFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding MediaFile}"
                                                                Padding="8,4" FontSize="12"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 空状态（无记录时显示） -->
                                    <TextBlock Text="暂无播放记录"
                                               FontSize="13" Foreground="#94A3B8"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"
                                               Visibility="{Binding HasRecentPlays, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
